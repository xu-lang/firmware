+
+#define TX_PATH_REG       0x80c
+#define TX_PATH_LOW_A     0x1111
+#define TX_PATH_LOW_B     0x2222
+#define TX_PATH_LOW_AB    0x3333
+#define RX_PATH_REG       0x808
+#define RX_PATH_LOW_A     0x11
+#define RX_PATH_LOW_B     0x22
+#define RX_PATH_LOW_AB    0x33
+#define CCK_RX_REG        0xa04
+
+static int proc_get_tx_path(struct seq_file *m, void *v)
+{
+	struct net_device *dev = m->private;
+	_adapter *adapter = (_adapter *)rtw_netdev_priv(dev);
+	u32 val = rtw_read32(adapter, TX_PATH_REG);
+	u16 low = val & 0xffff;
+
+	if (low == TX_PATH_LOW_B)
+		RTW_PRINT_SEL(m, "b\n");
+	else if (low == TX_PATH_LOW_AB)
+		RTW_PRINT_SEL(m, "ab\n");
+	else
+		RTW_PRINT_SEL(m, "a\n");
+	return 0;
+}
+
+static ssize_t proc_set_tx_path(struct file *file, const char __user *buffer, size_t count, loff_t *pos, void *data)
+{
+	struct net_device *dev = data;
+	_adapter *adapter = (_adapter *)rtw_netdev_priv(dev);
+	char input[4];
+	u32 val;
+	u16 low = TX_PATH_LOW_A, rx_low = RX_PATH_LOW_A;
+	u8 cck = 0;
+
+	if (count >= sizeof(input))
+		return -EINVAL;
+	if (copy_from_user(input, buffer, count))
+		return -EFAULT;
+	input[count] = '\0';
+
+	if (strncmp(input, "b", 1) == 0 || strncmp(input, "B", 1) == 0) {
+		low = TX_PATH_LOW_B;
+		rx_low = RX_PATH_LOW_B;
+		cck = 1;
+	} else if (strncasecmp(input, "ab", 2) == 0) {
+		low = TX_PATH_LOW_AB;
+		rx_low = RX_PATH_LOW_AB;
+		cck = 0;
+	} else {
+		rx_low = RX_PATH_LOW_A;
+		cck = 0;
+	}
+
+	val = rtw_read32(adapter, TX_PATH_REG);
+	val = (val & 0xffff0000) | low;
+	rtw_write32(adapter, TX_PATH_REG, val);
+
+	val = rtw_read32(adapter, RX_PATH_REG);
+	val = (val & 0xffffff00) | rx_low;
+	rtw_write32(adapter, RX_PATH_REG, val);
+
+	rtw_write32(adapter, CCK_RX_REG, cck);
+
+	RTW_INFO("proc_set_tx_path: TX=0x%x RX=0x%x CCK=%d\n", TX_PATH_REG, RX_PATH_REG, cck);
+
+	return count;
+}
